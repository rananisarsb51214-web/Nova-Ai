# https://REGION-YOUR_PROJECT.cloudfunctions.net/novaWebhookReceiver#!/bin/bash

# ==========================================
# COLOR CODES
# ==========================================
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}🚀 NISAR AI STUDIO - Multi-Cloud + Claude AI + Cloudflare${NC}"

# ==========================================
# STEP 1: DEPLOY TO ALL CLOUDS (AWS/GCP/Azure)
# ==========================================
echo -e "${YELLOW}📦 Step 1: Deploying to AWS...${NC}"
# (Assume AWS Terraform runs here)
cd terraform/aws && terraform apply -auto-approve
AWS_LB=$(terraform output -raw load_balancer_hostname)
echo -e "${GREEN}✅ AWS Load Balancer: $AWS_LB${NC}"
cd ../..

echo -e "${YELLOW}📦 Step 2: Deploying to GCP...${NC}"
cd terraform/gcp && terraform apply -auto-approve
GCP_LB=$(terraform output -raw load_balancer_ip)
echo -e "${GREEN}✅ GCP Load Balancer: $GCP_LB${NC}"
cd ../..

echo -e "${YELLOW}📦 Step 3: Deploying to Azure...${NC}"
cd terraform/azure && terraform apply -auto-approve
AZURE_LB=$(terraform output -raw load_balancer_dns)
echo -e "${GREEN}✅ Azure Load Balancer: $AZURE_LB${NC}"
cd ../..

# ==========================================
# STEP 2: INJECT CLAUDE API KEY INTO SECRETS
# ==========================================
echo -e "${YELLOW}🔑 Step 4: Injecting ANTHROPIC_API_KEY into all clouds...${NC}"

# AWS Secrets Manager
aws secretsmanager create-secret --name ANTHROPIC_API_KEY --secret-string "$ANTHROPIC_API_KEY" --region us-east-1

# GCP Secret Manager
echo -n "$ANTHROPIC_API_KEY" | gcloud secrets create ANTHROPIC_API_KEY --replication-policy="automatic" --data-file=-

# Azure Key Vault
az keyvault secret set --vault-name nisar-ai-vault --name ANTHROPIC-API-KEY --value "$ANTHROPIC_API_KEY"

echo -e "${GREEN}✅ Claude API Key injected into all clouds!${NC}"

# ==========================================
# STEP 3: CLOUDFLARE LOAD BALANCER (Multi-Cloud)
# ==========================================
echo -e "${YELLOW}🌐 Step 5: Configuring Cloudflare Global Load Balancer...${NC}"

cat > terraform/cloudflare/main.tf << 'EOF'
provider "cloudflare" {
  api_token = var.CLOUDFLARE_API_TOKEN
}

resource "cloudflare_load_balancer_monitor" "nisar" {
  type           = "http"
  path           = "/health"
  timeout        = 5
  retries        = 2
  expected_codes = "200"
}

resource "cloudflare_load_balancer_pool" "aws" {
  name    = "aws-pool"
  monitor = cloudflare_load_balancer_monitor.nisar.id
  origins { address = var.AWS_LB enabled = true weight = 1.0 }
}

resource "cloudflare_load_balancer_pool" "gcp" {
  name    = "gcp-pool"
  monitor = cloudflare_load_balancer_monitor.nisar.id
  origins { address = var.GCP_LB enabled = true weight = 1.0 }
}

resource "cloudflare_load_balancer_pool" "azure" {
  name    = "azure-pool"
  monitor = cloudflare_load_balancer_monitor.nisar.id
  origins { address = var.AZURE_LB enabled = true weight = 1.0 }
}

resource "cloudflare_load_balancer" "global" {
  zone_id = var.ZONE_ID
  name    = "api.nisar-ai.com"
  default_pool_ids = [
    cloudflare_load_balancer_pool.aws.id,
    cloudflare_load_balancer_pool.gcp.id,
    cloudflare_load_balancer_pool.azure.id,
  ]
  fallback_pool_id = cloudflare_load_balancer_pool.aws.id
  steering_policy  = "dynamic_latency"
  proxied          = true
}
EOF

cd terraform/cloudflare
terraform init
terraform apply -var="CLOUDFLARE_API_TOKEN=$CLOUDFLARE_API_TOKEN" \
  -var="ZONE_ID=$CLOUDFLARE_ZONE_ID" \
  -var="AWS_LB=$AWS_LB" \
  -var="GCP_LB=$GCP_LB" \
  -var="AZURE_LB=$AZURE_LB" \
  -auto-approve
cd ../..

# ==========================================
# FINAL OUTPUT
# ==========================================
echo -e "${GREEN}✅========================================${NC}"
echo -e "${GREEN}🌟 DEPLOYMENT COMPLETE!${NC}"
echo -e "${GREEN}🌍 Global API: https://api.nisar-ai.com${NC}"
echo -e "${GREEN}🤖 Primary AI: Gemini (Google)${NC}"
echo -e "${GREEN}🔄 Fallback AI: Claude (Anthropic)${NC}"
echo -e "${GREEN}☁️ Multi-Cloud: AWS (Primary) + GCP + Azure${NC}"
echo -e "${GREEN}🌐 Load Balancer: Cloudflare (Global Anycast)${NC}"
echo -e "${GREEN}✅========================================${NC}"